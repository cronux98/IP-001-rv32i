# =============================================================================
# IP-001 RV32I 5-Stage Pipeline Core — SDC Timing Constraints
# =============================================================================
# PDK:       SkyWater 130nm HD (sky130hd)
# Target:    50 MHz — period = 20.0 ns
# Domain:    Single synchronous clock, no CDC, no derived clocks
# =============================================================================

# ── Clock Definition ────────────────────────────────────────────────────────

# Primary clock: 50 MHz (20 ns period), 50% duty cycle
create_clock -name clk -period 20.0 -waveform {0.0 10.0} [get_ports clk]

# ── Clock Uncertainty ───────────────────────────────────────────────────────
# Conservative budget for sky130hd at 50 MHz:
#   Jitter:         ~0.1 ns (PLL/oscillator)
#   Skew:           ~0.2 ns (CTS insertion delay variation)
#   Margin:         ~0.1 ns (OCV / derating)
#   Total budget:   ~0.4 ns
set_clock_uncertainty -setup 0.4 [get_clocks clk]
set_clock_uncertainty -hold  0.2 [get_clocks clk]

# ── Input Delay Constraints ─────────────────────────────────────────────────
# I-Memory interface: instruction read data arrives from internal memory
#   Assumed I-mem access time: ~2.0 ns (sky130hd on-die SRAM)
#   Clock-to-out from memory macro: ~1.5 ns
#   Wire delay (short on-die): ~0.3 ns
#   Setup margin: ~0.2 ns
#   Total input delay: 1.5 + 0.3 + 0.2 = 2.0 ns
set_input_delay -clock clk -max 2.0 [get_ports i_rdata*]
set_input_delay -clock clk -min 0.5 [get_ports i_rdata*]

# D-Memory interface: load read data from internal data memory
#   Same timing assumptions as I-mem
set_input_delay -clock clk -max 2.0 [get_ports d_rdata*]
set_input_delay -clock clk -min 0.5 [get_ports d_rdata*]

# Interrupt inputs: asynchronous, sampled in ID/CSR stage
#   Generated by external logic, max 1 cycle path
#   Conservative: half-cycle budget for metastability synchronizer
set_input_delay -clock clk -max 8.0 [get_ports {irq_timer irq_external}]
set_input_delay -clock clk -min 0.0 [get_ports {irq_timer irq_external}]

# Reset input: async assertion, sync deassertion via 2-FF synchronizer
#   No timing constraint on assertion (async)
#   Recovery/removal handled by synchronizer, not SDC
set_input_delay -clock clk -max 2.0 [get_ports rst_n]
set_input_delay -clock clk -min 0.0 [get_ports rst_n]

# ── Output Delay Constraints ────────────────────────────────────────────────
# I-Memory address: sent to instruction memory
#   Capture by memory macro: ~1.0 ns setup
#   Wire delay: ~0.3 ns
#   Output delay = capture_req - wire = 1.0 + 0.3 = 1.3 ns
set_output_delay -clock clk -max 1.3 [get_ports i_addr*]
set_output_delay -clock clk -min 0.0 [get_ports i_addr*]

# D-Memory outputs: address, write data, byte-enable, write-enable
#   Same timing as I-mem address
set_output_delay -clock clk -max 1.3 [get_ports d_addr*]
set_output_delay -clock clk -max 1.3 [get_ports d_wdata*]
set_output_delay -clock clk -max 1.3 [get_ports d_be*]
set_output_delay -clock clk -max 1.3 [get_ports d_we]
set_output_delay -clock clk -min 0.0 [get_ports {d_addr* d_wdata* d_be* d_we}]

# ── False Paths ─────────────────────────────────────────────────────────────
# Single clock domain — no asynchronous crossings to declare false.
# If a synchronizer is added for interrupt inputs, declare:
#   set_false_path -from [get_ports {irq_timer irq_external}]
#   Uncomment after synchronizer RTL is complete.

# ── Load Constraints ────────────────────────────────────────────────────────
# Conservative drive/load for sky130hd typical cell
set_driving_cell -lib_cell sky130_fd_sc_hd__buf_1 -pin X [all_inputs]
set_load 0.05 [all_outputs]

# ── Operating Conditions ────────────────────────────────────────────────────
# Worst-case PVT for sky130hd: SS corner, 125°C, 1.62V
# Note: operating conditions are typically set by the liberty file;
# these are reminders for the STA run configuration.
#   -library sky130_fd_sc_hd__ss_125C_1v62.lib

# ── Multi-Cycle Paths ───────────────────────────────────────────────────────
# None identified for this design.
# All paths are single-cycle with ample slack (>10 ns at 50 MHz target).
# Critical path estimate: ~8 ns (fwd mux + ALU + setup) vs 20 ns period.

# =============================================================================
# End of IP_001.sdc
# =============================================================================
